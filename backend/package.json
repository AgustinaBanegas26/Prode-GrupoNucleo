{
  "name": "prode-backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start:jobs": "node src/jobs/startJobs.js",
    "sync:fixture": "node -e \"const {syncAllMatches}=require('./src/services/matchSync'); syncAllMatches().then(()=>process.exit(0)).catch(e=>{console.error(e); process.exit(1)})\"",
    "sync:finished": "node -e \"const {syncFinishedMatches}=require('./src/services/matchSync'); syncFinishedMatches().then(()=>process.exit(0)).catch(e=>{console.error(e); process.exit(1)})\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "axios": "^1.7.9",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3"
  }
}
