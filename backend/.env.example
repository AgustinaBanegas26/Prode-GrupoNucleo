# ── API Football (sincronización de resultados) ──────────────────────────────
API_FOOTBALL_KEY=tu_clave_aqui

# ── Supabase (base de datos) ──────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=tu_service_role_key_aqui

# ── JWT Secret (mismo que usa Supabase para firmar tokens) ───────────────────
# Se encuentra en: Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=tu_jwt_secret_aqui

# ── Puerto HTTP (Render lo asigna automáticamente) ───────────────────────────
PORT=3000
